{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Apex Launcher",
  "version": "1.0.5",
  "identifier": "com.apex.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Apex Launcher",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "maxWidth": 1280,
        "minHeight": 800,
        "maxHeight": 800,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "headerImage": null,
        "sidebarImage": null
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1MDU3MEQxRkIzNkYwRDkKUldUWjhEYjcwWEFGbFRQQkhwZ3lSK2MzYno3SFBXM0NweFVWMnFGNWlVeDhBd0M2dU1YUzdFQkkK",
      "endpoints": [
        "https://github.com/uziwif/Apex/releases/latest/download/latest.json"
      ]
    }
  }
}
